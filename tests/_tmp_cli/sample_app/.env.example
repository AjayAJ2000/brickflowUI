# BrickflowUI Environment Variables
# Copy this to .env and fill in your values for local development.
# In Databricks Apps, set these via app.yaml env section.

# ── Databricks Connection ──────────────────────────────────────────────────
# Your Databricks workspace URL (e.g. https://adb-1234.azuredatabricks.net)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net

# Personal Access Token (or use OAuth with Databricks SDK)
DATABRICKS_TOKEN=dapi...

# SQL Warehouse ID for data queries
DATABRICKS_WAREHOUSE_ID=your-warehouse-id

# ── Optional ───────────────────────────────────────────────────────────────
# Unity Catalog volume URI for file storage
# DATABRICKS_VOLUME_URI=/Volumes/catalog/schema/volume

# Override server port (default: 8050 locally, set by Databricks Apps at runtime)
# BRICKFLOWUI_PORT=8050
